{
  "name": "prd-endpoint-validation",
  "version": "1.0.0",
  "description": "Analyse PRD endpoints for compliance",
  "main": "./app.js",
  "scripts": {
    "start:prd": "npm run build && node ./dist/app.js",
    "start:dh": "npm run build && node ./dist/runDataholderTests.js",
    "build": "tsc && mkdir -p ./dist/collections && mkdir -p ./dist/environments  && mkdir -p ./dist/iteration-data  && cp ./src/environments/* ./dist/environments/ && cp ./src/collections/* ./dist/collections/ && cp ./src/iteration-data/* ./dist/iteration-data/ ",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon"
  },
  "author": "Tomas Schier",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.13",
    "nodemon": "^2.0.13",
    "ts-node": "^10.3.0",
    "tslint": "^6.1.3",
    "typescript": "^4.4.4"
  },
  "dependencies": {
    "@cds-au/holder-sdk": "2.0.4",
    "@types/body-parser": "^1.19.2",
    "@types/consumer-data-standards": "^7.2.0",
    "@types/express-serve-static-core": "^4.17.30",
    "@types/newman": "^5.3.6",
    "body-parser": "^1.20.0",
    "express": "^4.17.1",
    "newman": "^6.1.3",
    "newman-reporter-htmlextra": "^1.23.1",
    "newman-reporter-teamcity": "^0.1.12",
    "sync-request": "^6.1.0"
  }
}
